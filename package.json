{
  "name": "vectfox-tests",
  "version": "1.0.0",
  "description": "Automated tests for VectFox RAG extension",
  "type": "module",
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
