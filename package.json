    "test:e2e": "playwright test",
    "test:e2e:report": "playwright show-report"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@vitest/coverage-v8": "^2.1.0",
    "@vitest/ui": "^2.1.0",
    "jieba-wasm": "^2.4.0",
    "jsdom": "^27.0.1",
    "vitest": "^2.1.0"
  }
}
